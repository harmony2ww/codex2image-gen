# Optional — copy to .env in this directory before starting the proxy.
# Leave PROXY_API_KEY unset for local-only use with no HTTP token.

# Require Bearer token on API requests (recommended when exposing beyond localhost):
# PROXY_API_KEY=your-strong-random-token

# CODEX_HOME=~/.codex
# CODEX_BINARY=/Applications/Codex.app/Contents/Resources/codex
